is_dialog_thought = true
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_cdvyr"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "Mamma, Njai looked scared. Is she alright?"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_465j4"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "Schatje, Pappa scolded Njai because she was wrong."
translation = "Dear"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_3ol13"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "She did something bad, hence why your Pappa was so angry."
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_prfth"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "Pappa and Mamma wanted the best for you—for us"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_0bl42"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "as tomorrow we would go back to Pappa’s work."
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_e2c8k"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "It would be bad if our time together is ruined because of Njai’s mistake"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_vuxrn"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "don’t you think?"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_4tftr"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "(nods slowly)"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_aljrv"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "Even so, is it allowed?"
is_dialog_thought = true
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_m8agl"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "It’s alright, Liefje. Pappa will be back next Saturday."
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_s6kb3"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "Pappa will bring you more toys"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_ge2tl"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "more of your favorite sweets!"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_x5twj"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "Thank you, Mamma."
