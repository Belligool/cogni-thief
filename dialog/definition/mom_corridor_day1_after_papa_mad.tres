[sub_resource type="Resource" id="Resource_u3ne6"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "Schatje, is it not to your taste?"
translation = "Dear, is it not to your taste? "
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_nq1pr"]
script = ExtResource("1_p1rai")
speaker = "moeder"
text = "Do you want Njai to make a new one for you?"
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_i7t2x"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "Mamma is worried… about a mere tea?"
is_dialog_thought = true
metadata/_custom_type_script = "uid://nw5gof71bqt3"

[sub_resource type="Resource" id="Resource_b7h1x"]
script = ExtResource("2_lq0cu")
label = "Mamma, Njai looked scared… is she alright?"
point_type = 1
next_line_index = 4
metadata/_custom_type_script = "uid://dlfh74f7gy1re"

[sub_resource type="Resource" id="Resource_xt2uk"]
script = ExtResource("2_lq0cu")
label = "No, Mamma. The tea tasted great."
next_line_index = 19
metadata/_custom_type_script = "uid://dlfh74f7gy1re"

[sub_resource type="Resource" id="Resource_ff1u6"]
script = ExtResource("2_lq0cu")
label = "Mamma, I don’t like this tea!"
point_type = 2
next_line_index = 25
metadata/_custom_type_script = "uid://dlfh74f7gy1re"

[sub_resource type="Resource" id="Resource_28qex"]
script = ExtResource("1_p1rai")
speaker = "mc"
text = "After Pappa looked so angry?"
